# 飞书应用凭证（在飞书开放平台创建企业自建应用后获取）
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# QQ 机器人凭证（在 bot.q.qq.com 创建应用后获取）
# QQ_APP_ID=xxxxxxxxxxxxxxxx
# QQ_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude Code 可执行文件路径（默认 claude，如已在 PATH 中则无需修改）
CLAUDE_BIN=claude

# 执行工作目录（默认为启动 pocket-relay 时的当前目录）
# CLAUDE_CWD=/path/to/your/project

# 任务超时时间（毫秒，默认 10 分钟）
TASK_TIMEOUT_MS=600000
